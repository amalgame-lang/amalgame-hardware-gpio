// Stdlib test: Amalgame.Hardware — GPIO digital I/O.
//
// These assertions are hardware-free: they exercise the API surface
// and the libgpiod v2 binding without needing a real (or simulated)
// gpiochip. The on-hardware / gpio-sim smoke test lives in
// tests/run_tests.sh, which loads a virtual chip when the kernel
// supports it.
//
// What we can assert deterministically anywhere:
//   - Backend() returns a non-empty libgpiod version string (proves
//     the v2 library is actually linked).
//   - PinMode() on an out-of-range offset fails cleanly (false),
//     never crashes.
//   - DigitalRead() on an unconfigured pin is Level.Low, not a trap.
//   - Close() is idempotent.

namespace Tests

import Amalgame.Hardware

public class Program {
    public static void Main(string[] args) {
        var pass: int = 0
        var fail: int = 0

        // ── Backend() proves libgpiod is linked ──
        let v: string = Gpio.Backend()
        if (v != "") {
            Console.WriteLine("[PASS] backend-version (" + v + ")")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] backend-version empty")
            fail = fail + 1
        }

        // ── Out-of-range pin → PinMode returns false, no crash ──
        if (!Gpio.PinMode(99999, PinMode.Output)) {
            Console.WriteLine("[PASS] pinmode-out-of-range-false")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] pinmode-out-of-range-false")
            fail = fail + 1
        }

        // ── DigitalRead on an unconfigured pin is Low, not a trap ──
        if (Gpio.DigitalRead(99999) == Level.Low) {
            Console.WriteLine("[PASS] read-unconfigured-low")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] read-unconfigured-low")
            fail = fail + 1
        }

        // ── WatchEdge on an out-of-range pin → false ──
        if (!Gpio.WatchEdge(99999, Edge.Both)) {
            Console.WriteLine("[PASS] watchedge-out-of-range-false")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] watchedge-out-of-range-false")
            fail = fail + 1
        }

        // ── WaitEdge with nothing watched → timeout sentinel ──
        let ev: GpioEvent = Gpio.WaitEdge(0)
        if (ev.IsTimeout()) {
            Console.WriteLine("[PASS] waitedge-timeout-when-idle")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] waitedge-timeout-when-idle")
            fail = fail + 1
        }

        // ── PollEdges with nothing watched → empty list ──
        let evs: List<GpioEvent> = Gpio.PollEdges()
        if (evs.Count() == 0) {
            Console.WriteLine("[PASS] polledges-empty-when-idle")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] polledges-empty-when-idle")
            fail = fail + 1
        }

        // ── I2c on a non-existent bus → not open, ops fail safely ──
        let badBus: I2c = new I2c(99)
        if (!badBus.IsOpen()) {
            Console.WriteLine("[PASS] i2c-open-missing-bus-false")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] i2c-open-missing-bus-false")
            fail = fail + 1
        }
        if (badBus.ReadByte(0x68) == -1) {
            Console.WriteLine("[PASS] i2c-read-closed-minus1")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] i2c-read-closed-minus1")
            fail = fail + 1
        }
        let found: List<int> = badBus.Scan()
        if (found.Count() == 0) {
            Console.WriteLine("[PASS] i2c-scan-closed-empty")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] i2c-scan-closed-empty")
            fail = fail + 1
        }
        badBus.Close()

        // ── Spi on a non-existent device → not open, Transfer empty ──
        let badSpi: Spi = new Spi(99, 99)
        if (!badSpi.IsOpen()) {
            Console.WriteLine("[PASS] spi-open-missing-dev-false")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] spi-open-missing-dev-false")
            fail = fail + 1
        }
        let tx: List<int> = new List<int>()
        tx.Add(0x9F)
        let rx: List<int> = badSpi.Transfer(tx)
        if (rx.Count() == 0) {
            Console.WriteLine("[PASS] spi-transfer-closed-empty")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] spi-transfer-closed-empty")
            fail = fail + 1
        }
        badSpi.Close()

        // ── Close() is idempotent ──
        Gpio.Close()
        Gpio.Close()
        Console.WriteLine("[PASS] close-idempotent")
        pass = pass + 1

        Console.WriteLine("---")
        Console.WriteLine(String_FromInt(pass) + " passed, " +
                          String_FromInt(fail) + " failed")
        // The runner greps stdout for "[FAIL]" to decide the exit
        // status — AM's Main is void and there's no exposed exit().
    }
}
